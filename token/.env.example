# Deployer private key. NEVER commit this file with a real value, and never
# paste a real private key into chat/logs. Use a dedicated deployment wallet
# funded with just enough BNB for gas - not a wallet holding other funds.
PRIVATE_KEY=

# RPC endpoints (public defaults are used if left blank)
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Optional: for `hardhat verify` on BscScan
BSCSCAN_API_KEY=

# Total initial supply to mint to the deployer, in whole DUSD (18 decimals assumed)
INITIAL_SUPPLY=1000000000
