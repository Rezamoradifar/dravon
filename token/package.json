{
  "name": "dravonusd-token",
  "version": "1.0.0",
  "private": true,
  "description": "DravonUSD (DUSD) BEP-20 token contract and deployment scripts for BNB Smart Chain.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
