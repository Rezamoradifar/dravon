# WalletConnect Cloud project id (required by RainbowKit) - https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# The Factory contract that deploys/tracks round windows (display + reference only,
# its own ABI is not part of this project since it wasn't provided)
NEXT_PUBLIC_FACTORY_ADDRESS=0x078E0D325E09B9E8E9a07A4BD2D5848319D5692A

# The current/latest Window (round) contract - this is the contract the whole app
# reads from and writes to using the ABI in /contracts/roundWindowAbi.ts
NEXT_PUBLIC_WINDOW_ADDRESS=0xcDbe7d734d8153A9BC8282984D071ECaBdC281B6

# Chain id the contracts above are deployed on. Defaults to BNB Smart Chain (56).
NEXT_PUBLIC_CHAIN_ID=56

# Optional: RPC override for the primary chain (falls back to a public RPC otherwise)
NEXT_PUBLIC_RPC_URL=

# Client-side gate for the /admin panel. The provided ABI has no on-chain owner()
# getter, so this is a UX convenience only - it hides the admin UI for everyone
# except this address. It is NOT a security boundary: the contract itself is the
# real authority and will revert admin-only calls from unauthorized callers.
NEXT_PUBLIC_ADMIN_ADDRESS=

# Optional: block explorer base url override (auto-detected from chain otherwise)
NEXT_PUBLIC_EXPLORER_URL=

# Optional: public site URL used to build sitemap.xml entries
NEXT_PUBLIC_SITE_URL=

# Optional: BscScan API key (free at https://bscscan.com/apis). The contract ABI has
# no events, so without this key the Dashboard's Activity panel only shows
# transactions submitted from this browser. With it (and NEXT_PUBLIC_CHAIN_ID=56),
# it also shows the connected wallet's real on-chain history with the window contract.
NEXT_PUBLIC_BSCSCAN_API_KEY=
